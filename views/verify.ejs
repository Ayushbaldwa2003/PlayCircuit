<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Your Account</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f7;
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #fff;
      box-shadow: 0 0 18px rgba(0,0,0,0.08);
      border-radius: 10px;
      padding: 32px;
      width: min(420px, 92vw);
    }
    h1 {
      margin-top: 0;
      margin-bottom: 20px;
      font-size: 24px;
    }
    label {
      display: block;
      margin-bottom: 8px;
      font-weight: bold;
    }
    input[type="text"] {
      width: 100%;
      padding: 10px 12px;
      margin-bottom: 16px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 14px;
    }
    button {
      width: 100%;
      padding: 12px;
      border: none;
      border-radius: 6px;
      background: #0070f3;
      color: white;
      font-size: 16px;
      cursor: pointer;
    }
    .link {
      margin-top: 18px;
      text-align: center;
    }
    .link a {
      color: #0070f3;
      text-decoration: none;
    }
    .message {
      margin-bottom: 16px;
      padding: 12px;
      border-radius: 6px;
      background: #eef6ff;
      color: #0b3d91;
    }
    .error {
      margin-bottom: 16px;
      padding: 12px;
      border-radius: 6px;
      background: #ffe7e7;
      color: #911b1b;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>OTP Verification</h1>
    <% if (typeof error !== 'undefined') { %>
      <div class="error"><%= error %></div>
    <% } %>
    <% if (typeof info !== 'undefined') { %>
      <div class="message"><%= info %></div>
    <% } %>
    <form action="/user/verify" method="post">
      <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
      <input type="hidden" name="redirectTo" value="<%= typeof redirectTo !== 'undefined' ? redirectTo : '' %>">
      <label>Enter OTP</label>
      <input type="text" name="otp" required maxlength="6" placeholder="123456" />
      <button type="submit">Verify Account</button>
    </form>
    <div class="link">
      Already verified? <a href="/login?<%= typeof redirectTo !== 'undefined' && redirectTo ? 'redirectTo=' + encodeURIComponent(redirectTo) : '' %>">Login</a>
    </div>
  </div>
</body>
</html>