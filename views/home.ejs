<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Game Hub</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: #f5f6f8;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      padding: 20px;
    }

    .container {
      text-align: center;
      width: 100%;
      max-width: 400px;
    }

    h1 {
      margin-bottom: 24px;
      font-size: 28px;
      color: #111;
    }

    .game-card {
      background: white;
      padding: 20px 30px;
      border-radius: 12px;
      margin-top: 16px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
      transition: box-shadow 0.2s, transform 0.2s;
      cursor: pointer;
    }

    .game-card:hover {
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.15);
      transform: translateY(-2px);
    }

    .game-card a {
      text-decoration: none;
      font-size: 16px;
      font-weight: bold;
      color: white;
      background: black;
      display: block;
      padding: 12px;
      border-radius: 8px;
      transition: background 0.2s;
    }

    .game-card a:hover {
      background: #333;
    }

    @media (max-width: 480px) {
      .container {
        padding: 10px;
      }

      h1 {
        font-size: 22px;
      }
    }
  </style>
</head>

<body>
  <div class="container">
    <h1>🎮 Game Hub</h1>

    <div class="game-card">
      <a href="/game/nim">Play Nim Game</a>
    </div>
  </div>
</body>
</html>
