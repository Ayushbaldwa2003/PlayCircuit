<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Local Nim Game</title>
  <link rel="stylesheet" href="/css/nim/local.css" />
</head>
<body>

  <div class="container">

    <h1>Nim Game &mdash; Player vs Bot</h1>

    <h3 id="status">Your Turn</h3>

    <div class="stone-box">
      <p class="stone-label">Remaining Stones</p>
      <span id="sticks-count">17</span>
    </div>

    <p id="start-info"></p>

    <div class="btn-group">
      <button onclick="playerMove(1)">Remove 1</button>
      <button onclick="playerMove(2)">Remove 2</button>
      <button onclick="playerMove(3)">Remove 3</button>
    </div>

    <div class="divider"></div>

    <button id="rematchBtn" onclick="restartGame()">
      Rematch
    </button>

  </div>

  <script src="/js/nim/local.js"></script>

</body>
</html>
