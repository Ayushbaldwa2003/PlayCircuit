<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f5f6f8;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
        }

        input {
            width: 100%;
            padding: 12px;
            margin: 10px 0;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 14px;
        }

        button {
            width: 100%;
            padding: 12px;
            background: black;
            color: white;
            border: none;
            border-radius: 8px;
            margin-top: 10px;
            cursor: pointer;
            font-size: 15px;
        }

        button:hover {
            opacity: 0.9;
        }

        .google-btn {
            background: white;
            color: black;
            border: 1px solid #ccc;
        }

        .divider {
            text-align: center;
            margin: 15px 0;
            color: gray;
            font-size: 14px;
        }

        .link {
            text-align: center;
            margin-top: 15px;
            font-size: 14px;
        }

        a {
            text-decoration: none;
            font-weight: bold;
            color: black;
        }

        /* Mobile optimization */
        @media (max-width: 480px) {
            .card {
                padding: 20px;
            }

            h1 {
                font-size: 22px;
            }
        }
    </style>
</head>

<body>
    <div class="card">
        <h1>Login</h1>
        <% if (typeof error !=='undefined' ) { %>
            <p style="color: red; text-align: center;">
                <%= error %>
            </p>
            <% } %>
                <form action="/user/login" method="post">
                    <% if (typeof error !== 'undefined') { %>
                      <p style="color: red; text-align: center;"><%= error %></p>
                    <% } %>
                    <label>Email</label>
                    <input type="text" required name="email" value="<%= typeof email !== 'undefined' ? email : '' %>" />

                    <input type="hidden" name="redirectTo" value="<%= typeof redirectTo !== 'undefined' ? redirectTo : '' %>">

                    <label>Password</label>
                    <input type="text" required name="password" />

                    <button type="submit">Log In</button>
                </form>

                <div class="link">
                    Don't have an account yet? <a href="/signup?<%= typeof redirectTo !== 'undefined' && redirectTo ? 'redirectTo=' + encodeURIComponent(redirectTo) : '' %>">Signup</a>
                </div>
    </div>
</body>

</html>