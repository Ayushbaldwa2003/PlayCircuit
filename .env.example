# Copy this file to .env for local development
# Do not commit your real secrets to GitHub

PORT=5100
MONGO_URI=mongodb://127.0.0.1:27017/multiplayer-gaming-site
# Render and many MongoDB providers also use MONGODB_URI or DATABASE_URL
# If your provider uses one of those, set that env name instead of MONGO_URI.
# MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/dbname?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
